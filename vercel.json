{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/job", "destination": "/api/job" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
