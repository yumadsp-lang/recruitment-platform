{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.wejobs.ro" }],
      "destination": "https://wejobs.ro/:path*",
      "permanent": true
    },
    {
      "source": "/job.html",
      "destination": "/job",
      "permanent": true
    },
    {
      "source": "//job",
      "destination": "/job",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/job", "destination": "/api/job" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
